{
    "org-openroadm-device": {
        "interface": [
            {
                "name": "eth-1/2/OAMP",
                "type": "org-openroadm-interfaces:ethernetCsmacd",
                "supporting-circuit-pack-name": "1/2",
                "supporting-port": "OAMP",
                "ethernet": {
                    "speed": "1000",
                    "duplex": "full",
                    "auto-negotiation": "false"
                },
                "ipv4": {
                    "enabled": "false",
                    "forwarding": "false",
                    "dhcpc-enabled": "false"
                },
                "ipv6": {
                    "enabled": "false",
                    "forwarding": "false",
                    "dhcpc-enabled": "false",
                    "address": [
                        {
                            "ip": "__IPADDRESS",
                            "prefix-length": "__PREFIXLENGTH"
                        }
                    ]
                }
            }
        ],
        "routing": {
            "routing-instance": [
                {
                    "name": "MCN",
                    "type": "org-openroadm-routing:default-routing-instance",
                    "enabled": "true",
                    "routing-protocols": {
                        "routing-protocol": [
                            {
                                "type": "org-openroadm-routing:static",
                                "name": "STATIC",
                                "static-routes": {
                                    "ipv6": {
                                        "route": [
                                            {
                                                "destination-prefix": "::/0",
                                                "next-hop": {
                                                    "next-hop-address": "__DEFAULTGATEWAY"
                                                }
                                            }
                                        ]
                                    }
                                }
                            }
                        ]
                    }
                }
            ]
        }
    }
}
